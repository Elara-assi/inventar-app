{
  "name": "inventar-app",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "smoke": "node scripts/smoke-check.mjs",
    "db:reset": "python scripts/db-reset.py",
    "api": "python -m uvicorn app.main:app --app-dir apps/api --reload --port 8000"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
